generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model MenuItem {
  id           String   @id @default(uuid())
  name         String
  description  String?
  price        Float
  isVeg        Boolean  @default(true)
  category     String
  isTodaySpec  Boolean  @default(false)
  isBestSeller Boolean  @default(false)
  isSoldOut    Boolean  @default(false)
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ComboOffer {
  id          String   @id @default(uuid())
  title       String
  description String?
  price       Float
  items       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Settings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
}

model Faq {
  id       String  @id @default(uuid())
  question String
  answer   String
  isActive Boolean @default(true)
}

model SubscriptionPlan {
  id        String  @id @default(uuid())
  name      String
  mealType  String
  price     Float
  isPopular Boolean @default(false)
}
